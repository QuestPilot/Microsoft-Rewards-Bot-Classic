{
  "name": "microsoft-rewards-bot",
  "version": "3.62.9",
  "description": "Classic Microsoft Rewards automation for the old Rewards dashboard",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/QuestPilot/Microsoft-Rewards-Bot-Classic.git"
  },
  "bugs": {
    "url": "https://github.com/QuestPilot/Microsoft-Rewards-Bot-Classic/issues"
  },
  "homepage": "https://github.com/QuestPilot/Microsoft-Rewards-Bot-Classic#readme",
  "scripts": {
    "node:check": "node ./scripts/check-node-version.js",
    "prestart": "node ./scripts/check-node-version.js",
    "start": "node ./scripts/start.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:clean": "npm run clean && npm run build",
    "dev": "ts-node ./src/index.ts -dev",
    "test": "node --test --require ts-node/register \"tests/**/*.test.ts\"",
    "creator": "ts-node ./src/account-creation/cli.ts",
    "dashboard": "node ./scripts/start.js --dashboard",
    "dashboard:dev": "ts-node ./src/index.ts -dashboard",
    "update": "node ./scripts/installer/update.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "docker:build": "docker build -f docker/Dockerfile -t microsoft-rewards-bot .",
    "docker:run": "docker run -d --name ms-rewards microsoft-rewards-bot",
    "docker:compose": "docker compose -f docker/compose.yaml up -d",
    "docker:logs": "docker logs -f ms-rewards",
    "docker:stop": "docker stop ms-rewards && docker rm ms-rewards",
    "kill:chrome": "node -e \"const { execSync } = require('child_process'); const isWin = process.platform === 'win32'; try { execSync(isWin ? 'taskkill /F /IM chrome.exe 2>nul || exit 0' : 'pkill -f chrome || true', {stdio: 'inherit'}); } catch(e) {}\""
  },
  "keywords": [
    "Bing Rewards",
    "Microsoft Rewards",
    "Bot",
    "Script",
    "TypeScript",
    "Playwright",
    "Cheerio"
  ],
  "author": "QuestPilot",
  "contributors": [
    "Microsoft Rewards Bot Classic contributors (https://github.com/QuestPilot/Microsoft-Rewards-Bot-Classic/graphs/contributors)"
  ],
  "license": "CC-BY-NC-SA-4.0",
  "funding": {
    "type": "other",
    "url": "https://github.com/QuestPilot"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.19.0",
    "@types/node-cron": "3.0.11",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "eslint": "^8.57.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "ms": "^2.1.3",
    "node-cron": "3.0.3",
    "playwright": "1.52.0",
    "rebrowser-playwright": "1.52.0",
    "socks-proxy-agent": "^8.0.5",
    "ts-node": "^10.9.2",
    "ws": "^8.21.0"
  }
}
